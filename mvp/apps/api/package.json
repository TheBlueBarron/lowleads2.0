{
  "name": "@lowleads/api",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "jest --testPathPattern='src/.*\\.test\\.ts$' --passWithNoTests",
    "test:integration": "jest --testPathPattern='integration\\.test\\.ts$' --runInBand --forceExit"
  },
  "dependencies": {
    "@aws-sdk/client-kms": "^3.614.0",
    "@aws-sdk/client-secrets-manager": "^3.614.0",
    "@aws-sdk/client-ses": "^3.614.0",
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@lowleads/db": "workspace:*",
    "@lowleads/shared-types": "workspace:*",
    "@sinclair/typebox": "^0.33.14",
    "argon2": "^0.40.3",
    "fastify": "^4.28.1",
    "fastify-plugin": "^4.5.1",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "otplib": "^12.0.1",
    "pg": "^8.12.0",
    "qrcode": "^1.5.4",
    "stripe": "^16.0.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.2",
    "ts-jest": "^29.2.4",
    "tsx": "^4.16.2",
    "typescript": "*"
  }
}
